rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'primeimportsbdu@gmail.com';
    }

    // Helper function to check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Products: Publicly readable, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories: Publicly readable, only admin can write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: Public can create, only admin can read/update all
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Requested Items: Public can create, only admin can read all
    match /requestedItems/{itemId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Golden Circle Users: Auth users can read/write their own data, admin has full access
    match /goldenCircleUsers/{userId} {
      allow read, write: if isAdmin() || (isAuth() && request.auth.uid == userId);
    }

    // Tickets: Auth users can create and read their own, admin can do anything
    match /tickets/{ticketId} {
      allow create: if isAuth();
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
